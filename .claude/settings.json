{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(docker compose *)",
      "Bash(docker ps*)",
      "Bash(docker exec*)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git pull*)",
      "Bash(git merge *)",
      "Bash(curl -s \"http://localhost:*\")",
      "Bash(python3 -m json.tool)",
      "Bash(node -e *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *://!(localhost)*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets*)"
    ]
  }
}
