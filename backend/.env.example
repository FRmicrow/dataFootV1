# Database (required)
DATABASE_URL=postgres://YOUR_USER:YOUR_PASSWORD@localhost:5432/statfoot

# API-Football credentials (https://www.api-football.com/)
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Server
PORT=3001

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-west-3
S3_BUCKET_NAME=your_bucket_name

# Admin operations protection — route /api/v4/admin/* requires X-Admin-Key header
# Generate with: openssl rand -hex 16
# Default for local testing: (replace with your generated key)
ADMIN_SECRET_KEY=your-generated-key-here