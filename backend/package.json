{
  "name": "statfoot-backend",
  "version": "1.0.0",
  "description": "Backend server for Football Player Database",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node --max-old-space-size=4096 src/server.js",
    "dev": "node --max-old-space-size=4096 --watch src/server.js",
    "init-db": "node scripts/initDatabase.js",
    "migrate": "node scripts/v3/migrate.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "football",
    "api",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "1.13.6",

    "canvas": "^3.2.1",
    "colorthief": "^2.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "supertest": "7.2.2",
    "vitest": "2.1.9"
  }
}
