{
  "name": "statfoot-backend",
  "version": "1.0.0",
  "description": "Backend server for Football Player Database",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node --max-old-space-size=4096 src/server.js",
    "dev": "node --max-old-space-size=4096 --watch src/server.js",
    "init-db": "node scripts/initDatabase.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "football",
    "api",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.5",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.2.1",
    "supertest": "^6.3.4",
    "vitest": "^1.2.1"
  }
}
